html, body {
  margin: 0;
  font-family: 'Segoe UI';
  background: #f5f7fb;
}

.container {
  max-width: 1100px;
  margin: auto;
  padding: 20px;
}

h1 {
  text-align: center;
  color: #1e3c72;
}

.tabs {
  display: flex;
  justify-content: center;
  gap: 8px;
  margin: 20px 0;
}

.tabs button {
  padding: 8px 14px;
  border-radius: 20px;
  border: none;
  background: #e0e7ff;
}

.tabs button.active {
  background: #4f46e5;
  color: white;
}

.cards {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.card {
  flex: 1;
  padding: 15px;
  background: white;
  border-radius: 12px;
  text-align: center;
}

.paid { border-left: 4px solid green; }
.balance { border-left: 4px solid red; }

.controls {
  margin-top: 15px;
  display: flex;
  justify-content: space-between;
}

.search-box {
  display: flex;
  gap: 10px;
  align-items: center;
}

input {
  padding: 10px;
  border-radius: 8px;
  border: 1px solid #ccc;
}

button {
  padding: 10px;
  border-radius: 8px;
  border: none;
  background: #4f46e5;
  color: white;
}

.table-wrapper {
  overflow-x: auto;
  margin-top: 15px;
}

table {
  width: 100%;
  background: white;
  border-collapse: collapse;
}

th, td {
  padding: 10px;
  text-align: center;
  border-bottom: 1px solid #eee;
}

.name-cell {
  font-weight: 600;
}

.att-box {
  width: 18px;
  height: 18px;
  display: inline-block;
  margin: 2px;
  border-radius: 4px;
  background: #e5e7eb;
  cursor: pointer;
}

.att-present { background: green; }
.att-absent { background: red; }

.modal {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  justify-content: center;
  align-items: center;
  background: rgba(0,0,0,0.4);
}

.modal-content {
  background: white;
  padding: 25px;
  border-radius: 14px;
  width: 320px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.modal-buttons {
  display: flex;
  gap: 10px;
}

.modal-buttons button {
  flex: 1;
}

.cancel {
  background: red;
}